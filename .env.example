# Release Note Generator - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# SUPABASE AUTHENTICATION (Required)
# ============================================
# Your Supabase project's anonymous/public key
# Find: Supabase Dashboard → Settings → API → anon/public
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Optional: Your Supabase project URL (can be extracted from token issuer)
# Find: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# ============================================
# AI INTEGRATION (Required for AI features)
# ============================================
# Your OpenRouter API key for generating release notes
# Find: OpenRouter Dashboard → Keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ============================================
# DATABASE (Required for production)
# ============================================
# PostgreSQL connection string (use Render Database for production)
# Format: postgresql://user:password@host:port/database_name
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# For local development, you can omit this and SQLite will be used

# ============================================
# GITHUB APP INTEGRATION (Required for webhooks)
# ============================================
# Your GitHub App's ID
# Find: GitHub App Settings → About
GITHUB_APP_ID=your-github-app-id

# Your GitHub App's private key (PEM format)
# Find: GitHub App Settings → Private Keys
# Note: If using a file path, make sure the file exists
# If using the key content directly, include the full PEM block
GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----

# Your GitHub App's webhook secret token
# Find: GitHub App Settings → Webhook
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ============================================
# LOCAL DEVELOPMENT NOTES
# ============================================
# For local testing, you can use SQLite by omitting DATABASE_URL
# Set SUPABASE_ANON_KEY and OPENROUTER_API_KEY at minimum

# ============================================
# SECURITY NOTES
# ============================================
# - Never commit this file or .env to version control
# - Use different keys for development and production
# - Rotate your keys periodically
# - Render environment variables are encrypted at rest
